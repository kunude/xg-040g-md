#!/bin/sh /etc/rc.common

# Alist init script
# Copyright (C) 2026 OpenWRT.org

START=99
STOP=10

USE_PROCD=1

start_service() {
    procd_open_instance
    procd_set_param command /usr/bin/alist server
    procd_set_param working_dir /etc/alist
    procd_set_param respawn
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

stop_service() {
    killall alist 2>/dev/null
}

restart_service() {
    stop_service
    sleep 1
    start_service
}