
#
# Target
#
CONFIG_TARGET_airoha=y
CONFIG_TARGET_airoha_an7581=y
CONFIG_TARGET_airoha_an7581_DEVICE_bell_xg-040g-md=y
CONFIG_ARCH_64BIT=y
CONFIG_aarch64=y
CONFIG_LINUX_6_12=y

#
# Airoha hardware
#
CONFIG_PACKAGE_airoha-en7581-npu-firmware=y
CONFIG_PACKAGE_kmod-phy-airoha-en8811h=y
CONFIG_PACKAGE_kmod-i2c-an7581=y

#
# Base system ─ 这是最核心、最小系统必须的
#
CONFIG_DEFAULT_base-files=y
CONFIG_DEFAULT_busybox=y                  # 精简版工具集，几乎所有命令都靠它
CONFIG_DEFAULT_ca-bundle=y                # 根证书集合（https/wget/curl 等必须）
CONFIG_DEFAULT_logd=y                     # 系统日志守护进程
CONFIG_DEFAULT_procd=y                    # init 系统 / 服务管理核心
CONFIG_DEFAULT_uci=y                      # 配置系统（/etc/config/*）
CONFIG_DEFAULT_urandom-seed=y             # 随机种子保存/恢复（加密相关）
CONFIG_DEFAULT_urngd=y                    # 用户空间 RNG 守护进程
CONFIG_DEFAULT_netifd=y                   # 网络接口管理核心
CONFIG_DEFAULT_mtd=y                      # Flash 操作工具
CONFIG_DEFAULT_fstools=y                  # 文件系统挂载/检查工具
CONFIG_DEFAULT_block-mount=y              # 块设备挂载支持（USB 盘等）
CONFIG_DEFAULT_libc=y
CONFIG_DEFAULT_libgcc=y

# ZRAM Support
CONFIG_ZRAM=y
CONFIG_ZRAM_DEF_COMP_LZ4=y
CONFIG_ZRAM_DEF_COMP="lz4"
CONFIG_ZRAM_MEMORY_TRACKING=y
CONFIG_ZSWAP=y
CONFIG_ZPOOL=y
CONFIG_ZBUD=y
CONFIG_Z3FOLD=y
CONFIG_ZSMALLOC=y

CONFIG_PACKAGE_uboot-envtools=y
CONFIG_PACKAGE_kmod-ubootenv-nvram=y
CONFIG_PACKAGE_uclient-fetch=y
CONFIG_PACKAGE_kmod-gpio-button-hotplug=y
CONFIG_PACKAGE_kmod-leds-gpio=y
CONFIG_PACKAGE_ubi-utils=y
CONFIG_PACKAGE_kmod-zram=y               # ZRAM kernel module
CONFIG_PACKAGE_zramswap=y                # ZRAM swap management
CONFIG_PACKAGE_zramctl=y                 # ZRAM control tools
CONFIG_MTD_UBI=y
CONFIG_UBIFS_FS=y

#
# Network ─ 基本 IPv4/IPv6 网络栈
#
# D-Bus and Avahi libraries (防止静态链接)
CONFIG_PACKAGE_dbus=y                    # D-Bus message bus system
CONFIG_PACKAGE_libdbus=y                 # D-Bus core library
CONFIG_PACKAGE_libdaemon=y               # Daemon library
CONFIG_PACKAGE_avahi-daemon=y            # Avahi daemon
CONFIG_PACKAGE_libavahi-client=y         # Avahi client library
CONFIG_PACKAGE_libavahi-common=y         # Avahi common library
CONFIG_PACKAGE_avahi-utils=y             # Avahi utilities

CONFIG_PACKAGE_dnsmasq=y             # DNS + DHCP + TFTP（可以用 full 版，支持更多功能）
CONFIG_PACKAGE_ip-full=y
CONFIG_IPV6=y                             # 全局 IPv6 支持（不是包，是内核选项）
CONFIG_DEFAULT_odhcp6c=y                  # IPv6 DHCP 客户端
CONFIG_DEFAULT_odhcpd-ipv6only=y          # IPv6-only DHCP 服务器（配合 dnsmasq）
CONFIG_PACKAGE_nftables=y                 # nft 核心工具
CONFIG_PACKAGE_firewall4=y                # nftables 版防火墙（取代旧 firewall）
CONFIG_PACKAGE_kmod-nfnetlink=y
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nf-flow=y
CONFIG_PACKAGE_kmod-nft-offload=y         # nft 硬件转发支持（如果芯片支持）
CONFIG_PACKAGE_ethtool-full=y             # 查看接口速率、双工模式、自动协商状态。

#
# 包管理器：apk
#
# 添加这一行（默认已由系统启用，但显式指定更保险）：
CONFIG_PACKAGE_apk=y
CONFIG_DEFAULT_apk-tools=y                # apk 主程序包
CONFIG_PACKAGE_apk-mbedtls=y
CONFIG_DEFAULT_openwrt-keyring=y          # 签名验证密钥环（apk 生态常用，且官方镜像默认带）

#
# PPPoE
#
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y

#
# SSH
#
CONFIG_PACKAGE_dropbear=y
CONFIG_DROPBEAR_SMALL_CODE=y
CONFIG_DROPBEAR_ED25519=y
CONFIG_DROPBEAR_CURVE25519=y

#
# USB
#
CONFIG_USB_SUPPORT=y
CONFIG_PACKAGE_kmod-usb-core=y
CONFIG_PACKAGE_kmod-usb2=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-xhci-hcd=y
CONFIG_PACKAGE_kmod-usb-xhci-mtk=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-usb-storage-extras=y

#
# Filesystem (extroot)
#
CONFIG_PACKAGE_fitblk=y
CONFIG_PACKAGE_blkid=y
CONFIG_PACKAGE_lsblk=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-fs-exfat=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-ubifs=y

#
# LuCI 语言
#
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-homeproxy-zh-cn=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y

#
# 额外添加的包（用户自定义，非核心默认）
#
# 关键共享库（防止静态链接）
CONFIG_PACKAGE_libexpat=y               # XML parsing library
CONFIG_PACKAGE_libgdbm=y                # GNU database library
CONFIG_PACKAGE_libipset=y               # IP set library
CONFIG_PACKAGE_libbz2=y                 # Bzip2 compression library
CONFIG_PACKAGE_libzstd=y                # Zstandard compression library
CONFIG_PACKAGE_liblzma=y                # LZMA compression library
CONFIG_PACKAGE_libnl-tiny=y             # Netlink library

CONFIG_PACKAGE_luci=y                 # Web 管理
CONFIG_PACKAGE_luci-ssl=y                 # LuCI HTTPS 支持
CONFIG_PACKAGE_luci-theme-argon=y         # 默认使用 Argon 主题
CONFIG_PACKAGE_luci-app-argon-config=y    # Argon 主题设置页面
CONFIG_PACKAGE_luci-theme-bootstrap=y     # 保留 bootstrap 主题包
CONFIG_PACKAGE_umdns=y                    # 本地 mDNS/zeroconf 支持（hostname.local 解析）
CONFIG_PACKAGE_kmod-mtd-rw=y              # MTD 分区临时写权限（用于 NAND/eMMC 恢复或刷写）
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_fwtool=y

#
# HomeProxy (代理软件)
#
CONFIG_PACKAGE_luci-app-homeproxy=y

#
# PassWall (代理软件)
#
CONFIG_PACKAGE_luci-app-passwall=y
# PassWall 核心代理组件 (注释掉避免与 homeproxy 循环依赖)
# CONFIG_PACKAGE_sing-box=y
CONFIG_PACKAGE_xray-core=y
# 可选：其他协议支持 (按需启用)
# CONFIG_PACKAGE_hysteria=y
# CONFIG_PACKAGE_naiveproxy=y
# CONFIG_PACKAGE_shadowsocks-rust-sslocal=y
# CONFIG_PACKAGE_v2ray-core=y

#
# 透明代理所需内核模块
#
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nf-socket=y


#
# DDNS-Go
#
CONFIG_PACKAGE_ddns-go=y
CONFIG_PACKAGE_luci-app-ddns-go=y
CONFIG_PACKAGE_luci-i18n-ddns-go-zh-cn=y


#
# UDPXY
#
CONFIG_PACKAGE_luci-app-udpxy=y
CONFIG_PACKAGE_luci-i18n-udpxy-zh-cn=y
CONFIG_PACKAGE_udpxy=y

#
# WireGuard
#
CONFIG_PACKAGE_luci-proto-wireguard=y
# CONFIG_PACKAGE_wireguard-tools=y
CONFIG_PACKAGE_kmod-wireguard=y

#
# QRencode
#
CONFIG_PACKAGE_qrencode=y

#
# Print Service (CUPS)
#
CONFIG_PACKAGE_cups=y                     # CUPS print server
CONFIG_PACKAGE_lpr=y                      # LPR line printer daemon
CONFIG_PACKAGE_lpq=y                      # LPR queue management tools
CONFIG_PACKAGE_libcups=y                  # CUPS core library
CONFIG_PACKAGE_libcupsimage=y             # CUPS image library (防止静态链接)
CONFIG_PACKAGE_cups-bsd=y                 # CUPS BSD utilities (防止静态链接)
CONFIG_PACKAGE_cups-client=y              # CUPS client library (防止静态链接)
CONFIG_PACKAGE_cups-filters=y             # CUPS filters (防止静态链接)

CONFIG_PACKAGE_kmod-usb-printer=y         # USB printer support
# 在 main 分支中使用标准的 luci-app-cups
CONFIG_PACKAGE_luci-app-cups=y            # LuCI interface for CUPS management (main branch)
# luci-app-cupsd 在 main 分支中可能不兼容，使用 luci-app-cups 替代

#
# Network & Proxy
#
CONFIG_PACKAGE_openclash=y                    # OpenClash proxy core
CONFIG_PACKAGE_luci-app-openclash=y           # OpenClash LuCI interface
CONFIG_PACKAGE_luci-i18n-openclash-zh-cn=y    # OpenClash Chinese language

#
# USB 硬盘睡眠管理
#
CONFIG_PACKAGE_hdparm=y                    # 硬盘参数设置工具
CONFIG_PACKAGE_sdparm=y                   # SCSI 设备参数设置工具
CONFIG_PACKAGE_hd-idle=y                  # 硬盘休眠守护进程
CONFIG_PACKAGE_kmod-usb-sd=y              # USB SD 卡支持

#
# USB Utilities
#
CONFIG_PACKAGE_usbutils=y                 # USB utilities (lsusb, usb-devices)

#
# OpenList File Listing Service - 使用共享库避免体积膨胀
CONFIG_PACKAGE_openlist=y                 # OpenList file listing service
CONFIG_PACKAGE_luci-app-openlist=y        # OpenList LuCI web interface
CONFIG_PACKAGE_luci-i18n-openlist-zh-cn=y # OpenList Chinese language

#
# Docker黑名单 - 减小固件体积
#
# 注释掉Docker相关包（减小9-14MB）
# CONFIG_PACKAGE_docker=y
# CONFIG_PACKAGE_dockerd=y
# CONFIG_PACKAGE_containerd=y
# CONFIG_PACKAGE_runc=y

#
# Performance Optimization - Linux 6.12.80
#
# MGLRU Full Feature - Multi-Gen LRU VM
CONFIG_LRU_GEN=y
CONFIG_LRU_GEN_ENABLED_DEFAULT=y
CONFIG_LRU_GEN_STATS=y
CONFIG_LRU_GEN_HISTORICAL_STATS=y
CONFIG_LRU_GEN_PGDEMOTE=y
CONFIG_LRU_GEN_PGDEMOTE_ZSMALLOC=y
CONFIG_LRU_GEN_PGDEMOTE_KSM=y
CONFIG_LRU_GEN_PGDEMOTE_KSM_RECLAIM=y

# Virtual Memory & VM Subsystem Optimization
CONFIG_VM_EVENT_COUNTERS=y
CONFIG_VMSTATS=y
CONFIG_VM_EVENTS=y
CONFIG_VMSTATS_INTERVAL=5000
CONFIG_VMSTATS_THRESHOLD=1000
CONFIG_VM_MAX_MAP_COUNT=65536
CONFIG_VM_MIN_FREE_KBYTES=32768
CONFIG_VM_VFS_CACHE_PRESSURE=50
CONFIG_VM_DIRTY_RATIO=15
CONFIG_VM_DIRTY_BACKGROUND_RATIO=5
CONFIG_VM_SWAPPINESS=60
CONFIG_VM_OVERCOMMIT_MEMORY=2
CONFIG_VM_OVERCOMMIT_RATIO=50
CONFIG_VM_PAGECACHE=100
CONFIG_VM_EXTFRAG_THRESHOLD=500

# Advanced VM Features
CONFIG_KSM=y
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_ALWAYS=y
CONFIG_TRANSPARENT_HUGEPAGE_MADVISE=y
CONFIG_MEMORY_HOTPLUG=y
CONFIG_MEMORY_HOTREMOVE=y
CONFIG_MMIO_STALE=y
CONFIG_MMIO_CACHE=y

# CPU Scheduler Optimization
CONFIG_SCHED_MC=y
CONFIG_SCHED_SMT=y
CONFIG_SCHED_AUTOGROUPS=y
#CONFIG_SCHED_DEBUG=y
CONFIG_SCHED_TUNE=y
CONFIG_SCHED_MIGRATION_COST_NS=500000
CONFIG_SCHED_LATENCY_NS=2000000
CONFIG_SCHED_MIN_GRANULARITY_NS=500000
CONFIG_SCHED_WAKEUP_GRANULARITY_NS=100000
CONFIG_SCHED_TUNABLE_SCALING=0
CONFIG_SCHED_NUM_AWARE=1

# CPU Frequency & Idle
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_DEFAULT_GOV_ONDEMAND=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_POWERSAVE=y
CONFIG_CPU_FREQ_GOV_USERSPACE=y
CONFIG_CPU_FREQ_GOV_CONSERVATIVE=y
CONFIG_CPU_IDLE=y
CONFIG_CPU_IDLE_GOV_LADDER=y
CONFIG_CPU_IDLE_GOV_MENU=y

# I/O Scheduler Optimization
CONFIG_IOSCHED_DEADLINE=y
CONFIG_IOSCHED_CFQ=y
CONFIG_IOSCHED_NOOP=y
CONFIG_IOSCHED_BFQ=y
CONFIG_BLK_CGROUP=y
CONFIG_BLK_WBT=y
CONFIG_BLK_WBT_SQ=y
CONFIG_BLK_WBT_MQ=y
CONFIG_BLK_WBT_DELAY=10
CONFIG_BLK_WBT_MAX=100
CONFIG_BLK_WBT_MIN=5
CONFIG_BLK_WBT_TARGET=80

#
# Build options
#
# CONFIG_DEVEL=y  # 禁用调试选项（防止调试符号）
CONFIG_CCACHE=y
CONFIG_CCACHE_DIR=/mnt/openwrt/ccache

# 编译优化选项（减小固件体积）
CONFIG_EXTRA_CFLAGS="-Os -s -fno-caller-saves -fno-plt"
CONFIG_EXTRA_LDFLAGS="-Wl,-Bdynamic -Wl,--strip-all"

# 确保剥离所有调试符号
CONFIG_STRIP=y
CONFIG_STRIP_ALL=y

# File system optimization


# Network optimization
CONFIG_PACKAGE_kmod-netfilter-conntrack=y

# Security and monitoring


# End of system optimization features
